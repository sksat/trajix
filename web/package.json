{
  "name": "trajix-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && mv dist/trajix/cesium dist/cesium && rm -r dist/trajix",
    "preview": "vite preview",
    "wasm:build": "wasm-pack build ../crates/trajix-wasm --target web --out-dir pkg",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev18.0",
    "cesium": "^1.138.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "trajix-wasm": "file:../crates/trajix-wasm/pkg",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@duckdb/node-api": "1.4.4-r.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "~5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-cesium": "^1.2.23",
    "vite-plugin-wasm": "^3.4.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
